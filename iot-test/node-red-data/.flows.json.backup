    {
        "id": "a5766340a7581dab",
        "type": "function",
        "z": "a0a659f2972f2724",
        "name": "Stocker le token (global)",
        "func": "if (msg.payload && msg.payload.access_token) {\n    global.set(\"api_token\", msg.payload.access_token);\n    node.status({fill:\"green\", shape:\"dot\", text:\"token à jour\"});\n} else {\n    node.status({fill:\"red\", shape:\"ring\", text:\"échec connexion\"});\n}\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 930,
        "y": 60,
        "wires": [
            [
                "7a0e6594ca879ebc"
            ]
        ]
    },
