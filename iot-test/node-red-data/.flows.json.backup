    {
        "id": "a0a659f2972f2724",
        "type": "tab",
        "label": "Smart Fishing - Pipeline complet",
        "disabled": false,
        "info": "Couvre les 7 capteurs. Le token JWT est récupéré au démarrage puis toutes les 50 minutes, stocké dans le contexte global (api_token), et réutilisé par chaque capteur protégé."
    },
    {
        "id": "mqtt_broker_local2",
        "type": "mqtt-broker",
        "name": "Mosquitto local (test)",
        "broker": "mosquitto",
        "port": "1883",
        "clientid": "",
        "usetls": false,
        "protocolVersion": "4",
        "keepalive": "60",
        "cleansession": true
    },
    {
        "id": "632cb5994522109b",
        "type": "inject",
        "z": "a0a659f2972f2724",
        "name": "Connexion (au démarrage + toutes les 50 min)",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "3000",
        "crontab": "",
        "once": true,
        "onceDelay": 1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 200,
        "y": 60,
        "wires": [
            [
                "de619092cd92d4bc"
            ]
        ]
    },
    {
        "id": "de619092cd92d4bc",
        "type": "function",
        "z": "a0a659f2972f2724",
        "name": "Construire la requête de login",
        "func": "msg.payload = \"username=noderd_system&password=bdgl2026\";\nmsg.headers = { \"content-type\": \"application/x-www-form-urlencoded\" };\nreturn msg;",
        "outputs": 1,
        "x": 470,
        "y": 60,
        "wires": [
            [
                "253304b8a90329b9"
            ]
        ]
    },
    {
        "id": "253304b8a90329b9",
        "type": "http request",
        "z": "a0a659f2972f2724",
        "name": "POST /auth/login",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://api:8000/auth/login",
        "tls": "",
