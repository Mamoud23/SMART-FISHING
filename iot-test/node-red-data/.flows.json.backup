    {
        "id": "e34c45a2cf7d41f9",
        "type": "function",
        "z": "a0a659f2972f2724",
        "name": "Construire la ligne InfluxDB",
        "func": "const parties = msg.topic.split('/');\nconst id_bateau = parties[2] || \"inconnu\";\nconst p = msg.payload || {};\n\nconst lat = Number(p.lat) || 0;\nconst lng = Number(p.lng) || 0;\nconst vitesse = Number(p.vitesse) || 0;\n\nconst ligne = `gps,id_bateau=${id_bateau} lat=${lat},lng=${lng},vitesse=${vitesse}`;\n\nmsg.payload = ligne;\nmsg.headers = {\n    \"Authorization\": \"Token BhvMTAanAUCzy3KTXxdJ14CDZpT1dJCzvALvHxl_q5SvfnpB3O30n5q34DoV8LPFlmRUuUoscHUxYbv1hZxjqw==\",\n    \"Content-Type\": \"text/plain\"\n};\n\nnode.status({fill:\"green\", shape:\"dot\", text:\"GPS → Influx\"});\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 160,
        "wires": [
            [
                "27a0dfed1590825b"
            ]
        ]
    },
    {
        "id": "27a0dfed1590825b",
        "type": "http request",
        "z": "a0a659f2972f2724",
        "name": "Écrire dans InfluxDB",
        "method": "POST",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "http://influxdb:8086/api/v2/write?org=smart_fishing&bucket=telemetrie_peche&precision=s",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
