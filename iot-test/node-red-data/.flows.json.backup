    {
        "id": "97fde4175943d6bc",
        "type": "function",
        "z": "a0a659f2972f2724",
        "name": "Construire le payload API",
        "func": "const id_bateau = msg.topic.split('/')[2];\nconst p = msg.payload || {};\nconst token = global.get(\"api_token\");\n\nif (!token) {\n    node.status({fill:\"red\", shape:\"ring\", text:\"Token manquant\"});\n    return null;\n}\n\nmsg.payload = {\n    id_bateau: id_bateau,\n    temp_celsius: Number(p.temp_celsius) || 0,\n    horodatage: new Date().toISOString()\n};\n\nmsg.headers = {\n    \"Authorization\": \"Bearer \" + token,\n    \"Content-Type\": \"application/json\"\n};\n\nnode.status({fill:\"blue\", shape:\"dot\", text:\"Température envoyée\"});\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 240,
        "wires": [
            [
                "0b982b85638e1366"
            ]
        ]
