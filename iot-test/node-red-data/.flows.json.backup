    {
        "id": "8151a2b74e0e37f3",
        "type": "mqtt in",
        "z": "a0a659f2972f2724",
        "name": "Température eau (fishing/boat/+/water_temp)",
        "topic": "fishing/boat/+/water_temp",
        "qos": "0",
        "datatype": "auto",
        "broker": "mqtt_broker_local2",
